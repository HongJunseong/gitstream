{
  "_comment": [
    "Databricks DLT 파이프라인 설정 예시.",
    "Databricks UI → Delta Live Tables → Create Pipeline 에서 JSON으로 붙여넣거나,",
    "REST API (POST /api/2.0/pipelines) / Terraform databricks_pipeline 리소스로 사용."
  ],

  "name": "github-events-dlt",

  "target": "github_events",

  "libraries": [
    {
      "notebook": {
        "path": "/Repos/<your-workspace-path>/gitstream/databricks/pipelines/github_events_dlt"
      }
    }
  ],

  "configuration": {
    "pipeline.kafka.bootstrap_servers": "broker1:9092,broker2:9092",
    "pipeline.kafka.topic":             "github.raw.events",
    "pipeline.kafka.starting_offsets":  "latest"
  },

  "clusters": [
    {
      "label": "default",
      "spark_conf": {
        "spark.databricks.delta.preview.enabled": "true"
      },
      "autoscale": {
        "min_workers": 1,
        "max_workers": 4,
        "mode": "ENHANCED"
      }
    }
  ],

  "continuous": true,

  "development": false,

  "photon": false,

  "channel": "CURRENT"
}
