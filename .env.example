# ── GitHub ────────────────────────────────────────────────────────────────── #
# Personal access token (fine-grained or classic).
# Without a token the unauthenticated rate limit is 60 req/hr.
# With a token it is 5000 req/hr.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Poller ────────────────────────────────────────────────────────────────── #
# Kafka broker (internal docker network address when running in compose)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Target topic
KAFKA_TOPIC=github.raw.events

# Fallback poll interval in seconds (GitHub overrides via X-Poll-Interval)
POLL_INTERVAL=60

# Maximum HTTP retry attempts per page fetch
MAX_RETRIES=5

# Maximum pages to fetch per poll cycle (100 events/page → 300 events max)
MAX_PAGES=3

# Path where ETag + last_event_id state is persisted inside the container
STATE_FILE=/tmp/poller_state.json

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── PostgreSQL (Airflow metadata DB) ──────────────────────────────────────── #
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=airflow

# ── Airflow ───────────────────────────────────────────────────────────────── #
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_in_prod
