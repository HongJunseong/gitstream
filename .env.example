# ── GitHub ────────────────────────────────────────────────────────────────── #
# Personal access token — 없으면 60 req/hr, 있으면 5000 req/hr
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Kafka (Redpanda Cloud 권장) ───────────────────────────────────────────── #
#
# [Bootstrap Server]  Overview → Bootstrap server address
KAFKA_BOOTSTRAP_SERVERS=seed-xxxx.any.us-east-1.mpx.prd.cloud.redpanda.com:9092
#
# [Credentials]  Security → Users → username / password
KAFKA_SASL_USERNAME=your-redpanda-username
KAFKA_SASL_PASSWORD=your-redpanda-password
#
# Redpanda Cloud 는 SASL_SSL + SCRAM-SHA-256 (값 변경 불필요)
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256

# ── Poller 동작 설정 ──────────────────────────────────────────────────────── #
KAFKA_TOPIC=github.raw.events

# 데모/테스트: 60  (빠른 확인용)
# 장기 운영:  300  (기본값)
POLL_INTERVAL=300

MAX_RETRIES=5
MAX_PAGES=3
STATE_FILE=/tmp/poller_state.json
LOG_LEVEL=INFO

# ── PostgreSQL (Airflow metadata DB) ──────────────────────────────────────── #
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=airflow

# ── Airflow ───────────────────────────────────────────────────────────────── #
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_in_prod

# ── Databricks ────────────────────────────────────────────────────────────── #
DATABRICKS_HOST=https://adb-xxxxxxxxxx.azuredatabricks.net
DATABRICKS_TOKEN=token
DATABRICKS_JOB_NAME=github-events-streaming